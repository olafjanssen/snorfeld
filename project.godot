; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="snorfeld"
run/main_scene="res://scenes/main/editor.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://autoload/event_bus.gd"
AppConfig="*res://autoload/app_config.gd"
LLMClient="*res://autoload/llm_client.gd"
BookService="*res://autoload/book_service.gd"
ThemeManager="*res://autoload/theme_manager.gd"
CommandBus="*uid://bq4mholrhrila"
AnalysisManager="*res://autoload/analysis_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=980
window/energy_saving/keep_screen_on=false
window/subwindows/embed_subwindows=false
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"
window/per_pixel_transparency/allowed=true

[dotnet]

project/assembly_name="snorfeld"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdscript-linter/plugin.cfg")

[gui]

theme/custom_font="uid://n6fo8pgkbo3j"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
textures/vram_compression/import_etc2_astc=true
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
